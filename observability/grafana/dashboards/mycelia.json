{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "🔗 Cycle Health", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "subnet_current_block", "instant": true, "legendFormat": "Block" }],
      "title": "Current Block",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "max": 50, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 10 }, { "color": "green", "value": 20 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 7, "x": 5, "y": 1 },
      "id": 2,
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "subnet_blocks_remaining_in_phase", "instant": true, "legendFormat": "Blocks Left" }],
      "title": "Blocks Remaining in Phase",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short",
          "mappings": [
            { "options": { "0": { "text": "Distribute" }, "1": { "text": "Train" }, "2": { "text": "Commit 1" }, "3": { "text": "Submission" }, "4": { "text": "Validate" }, "5": { "text": "Commit 2" }, "6": { "text": "Merge" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "subnet_current_phase_index", "instant": true, "legendFormat": "Phase" }],
      "title": "Current Phase",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 3 }, { "color": "green", "value": 5 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["last"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_dht_peers_count", "legendFormat": "Peers" }],
      "title": "DHT Peers",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "⚙️ Averager Performance", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }, "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "timeout" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 7, "w": 16, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(validator_avg_step_status{status=\"success\"}[5m])", "legendFormat": "success" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(validator_avg_step_status{status=\"timeout\"}[5m])", "legendFormat": "timeout" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(validator_avg_step_status{status=\"error\"}[5m])", "legendFormat": "error" }
      ],
      "title": "Averager Step Rate",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 6 },
      "id": 6,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_dht_peers_count", "legendFormat": "peers" }],
      "title": "DHT Peer Count",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }, "id": 102, "title": "🏆 Miner Scoring", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 5, "lineWidth": 2, "showPoints": "auto", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 7,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_miner_score", "legendFormat": "uid={{miner_uid}}" }],
      "title": "Miner Scores by UID",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }, "id": 103, "title": "⏱ Latency & Compute", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 23 },
      "id": 8,
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_eval_latency_seconds_sum / validator_eval_latency_seconds_count", "legendFormat": "avg" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.95, increase(validator_eval_latency_seconds_bucket[1h]))", "legendFormat": "p95 (1h)"}
      ],
      "title": "Eval Latency",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 23 },
      "id": 9,
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_model_load_latency_seconds_sum / validator_model_load_latency_seconds_count", "legendFormat": "avg" },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.95, increase(validator_model_load_latency_seconds_bucket[1h]))", "legendFormat": "p95 (1h)"}
      ],
      "title": "Model Load Latency",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" }, "unit": "decgbytes" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 23 },
      "id": 10,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_vram_allocated_bytes / 1e9", "legendFormat": "cuda:{{device}} (Current)" },
                  { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "validator_vram_peak_allocated_bytes / 1e9", "legendFormat": "cuda:{{device}} (Peak)" }],
      "title": "VRAM Allocated (GB)",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 }, "id": 104, "title": "⛓ Chain Reliability", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 31 },
      "id": 11,
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "chain_commit_latency_seconds_sum / chain_commit_latency_seconds_count", "legendFormat": "avg", "instant": false },
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.95, increase(chain_commit_latency_seconds_bucket[1h]))", "legendFormat": "p95 (1h)"},
        { "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "histogram_quantile(0.5, increase(chain_commit_latency_seconds_bucket[1h]))", "legendFormat": "p50 (1h)"}
      ],
      "title": "Chain Commit Latency",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "red", "mode": "fixed" }, "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "auto" }, "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 31 },
      "id": 12,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "rate(chain_rpc_errors_total[5m])", "legendFormat": "RPC errors/s" }],
      "title": "RPC Error Rate",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 }, "id": 105, "title": "🧠 Miner Training", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 39 },
      "id": 13,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "miner_training_loss", "legendFormat": "loss" }],
      "title": "Training Loss",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 39 },
      "id": 14,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "miner_perplexity", "legendFormat": "perplexity" }],
      "title": "Perplexity",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 39 },
      "id": 15,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "miner_aux_loss", "legendFormat": "aux loss" }],
      "title": "MoE Aux Loss",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 46 },
      "id": 16,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "miner_learning_rate", "legendFormat": "lr" }],
      "title": "Learning Rate",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 46 },
      "id": 17,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "miner_local_step_rate", "legendFormat": "tokens/s" }],
      "title": "Tokens per Second",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "spanNulls": true }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 46 },
      "id": 18,
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }, "expr": "miner_total_tokens", "legendFormat": "total tokens" }],
      "title": "Total Tokens Processed",
      "type": "timeseries"
    }

  ],
