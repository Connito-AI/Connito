# Copy this file to `.env` next to docker-compose.yml and edit the values.
#
#   cd connito/validator/docker
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d

# -------- Image --------
# Tag to run. Default is `:stable`, which only moves when maintainers cut
# a tagged release — Watchtower auto-upgrades when it does. Other options:
#   :staging          opt in to the pre-release channel (early access)
#   :vX.Y.Z           pin to a specific release (Watchtower will not upgrade)
#   :master-<sha>     pin to a specific master build (Watchtower will not upgrade)
IMAGE=ghcr.io/connito-ai/connito-validator:stable

# -------- Bittensor wallet --------
# Must already exist under BITTENSOR_WALLET_PATH and be registered on SN102.
WALLET_NAME=my_validator_coldkey
HOTKEY_NAME=my_validator_hotkey
BITTENSOR_WALLET_PATH=/home/CHANGE_ME/.bittensor/wallets

# -------- Persistent state --------
# Anything outside DATA_DIR is lost on every Watchtower upgrade. Make sure
# your validator.yaml writes checkpoints, expert groups, logs, etc. into
# /data/... (which maps to DATA_DIR on the host).
DATA_DIR=/opt/connito/data
CONFIG_PATH=/opt/connito/data/configs/validator.yaml

# -------- Optional: Weights & Biases --------
WANDB_API_KEY=
WANDB_MODE=online

# -------- Optional: Watchtower tuning --------
# Polling interval in seconds. Default 300 = 5 minutes.
WATCHTOWER_POLL_INTERVAL=300
# Slack notifications when an upgrade happens. Leave blank to disable.
WATCHTOWER_NOTIFICATIONS=
WATCHTOWER_NOTIFICATION_SLACK_HOOK_URL=
